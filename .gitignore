# ignore virtualenv's own files
*.pyc
*.pyo
*.py.class

# ignore virtualenv wrapper scripts
*.exe
*.cmd

# ignore virtualenv build directory
build

# ignore egg cache
*.egg-info
*.egg

# ignore virtualenv's site-packages
site-packages

# ignore virtualenv's dist-packages
dist-packages   

# ignore virtualenv's pycache
__pycache__

# ignore virtualenv's wheelhouse
wheelhouse

# ignore virtualenv's site
site

# ignore virtualenv's local
.pytest_cache

share

venv

.venv

pyvenv.cfg

*.zip

.claude
.serena

# local agent/tooling state (not part of the project)
.gcli
.lean-ctx

# mkdocs-resize-images: large source images and cache
assets/images-large
.resize-hash

# benchmark run outputs (keep the dir via .gitkeep)
benchmarks/results/*
!benchmarks/results/.gitkeep

# local scratch notebook (not part of the project)
playground.ipynb